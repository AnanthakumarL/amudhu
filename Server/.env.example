# Application Settings
APP_NAME=E-Commerce Admin Backend
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1
PORT=7999

# Weaviate Configuration
WEAVIATE_ENABLED=True
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_SCHEME=http

# MongoDB (Atlas)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=amudhu

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:7999

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Stripe
# IMPORTANT: Do not commit real secret keys. Use your Stripe dashboard to create test keys.
STRIPE_SECRET_KEY=
# Webhook signing secret for /api/v1/payments/webhook (starts with whsec_...)
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=inr

# Client base URL used to build Stripe success/cancel redirect URLs
CLIENT_URL=http://localhost:5173
